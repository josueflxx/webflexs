# FLEXS B2B Environment Configuration
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=flexs_project.settings.local
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Feature flags (incremental rollout)
FEATURE_API_V1_ENABLED=True
FEATURE_BACKGROUND_JOBS_ENABLED=False
FEATURE_ADVANCED_SEARCH_ENABLED=False
FEATURE_OBSERVABILITY_ENABLED=False
FEATURE_READ_ONLY_MODE=False
ORDER_REQUIRE_PAYMENT_FOR_CONFIRMATION=False
ALERT_PREPARING_STALE_DAYS=3
ALERT_HIGH_DEBT_THRESHOLD=500000
ALERT_IMPORT_ERROR_RATE_PERCENT=30

# DRF throttling defaults
DRF_RATE_ANON=60/min
DRF_RATE_USER=240/min
DRF_RATE_API_DEFAULT=180/min
DRF_RATE_API_CATALOG=240/min
DRF_RATE_API_ADMIN=300/min

# Admin presence
ADMIN_ONLINE_WINDOW_SECONDS=300
ADMIN_IDLE_WINDOW_SECONDS=90
ADMIN_PRESENCE_TOUCH_INTERVAL_SECONDS=30
ADMIN_PRESENCE_REFRESH_SECONDS=30
ADMIN_PRESENCE_EXCLUDED_USERS=admin,admin_tester

# Background jobs (Celery + Redis)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_DEFAULT_QUEUE=flexs-default
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False

# Optional observability
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENVIRONMENT=production

# Database (production only)
DB_NAME=flexs_db
DB_USER=flexs_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email (optional, for future use)
LOCAL_EMAIL_BACKEND=console
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=ventas@flexs.com.ar

# ARCA / WSFE (Phase 4)
ARCA_ALLOW_PRODUCTION=False
ARCA_TIMEOUT_SECONDS=30
ARCA_OPENSSL_BIN=openssl
ARCA_WSAA_SERVICE=wsfe
ARCA_WSAA_URL_HOMOLOGATION=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
ARCA_WSAA_URL_PRODUCTION=https://wsaa.afip.gov.ar/ws/services/LoginCms
ARCA_WSFE_URL_HOMOLOGATION=https://wswhomo.afip.gov.ar/wsfev1/service.asmx
ARCA_WSFE_URL_PRODUCTION=https://servicios1.afip.gov.ar/wsfev1/service.asmx
# Keys admiten slug o id de empresa. Se recomienda slug.
# Ejemplo listo para Flexs/Ubolt (reemplazar cuit/rutas):
ARCA_COMPANY_CONFIG_JSON={"Flexs":{"homologation":{"cuit":"20113124572","cert_path":"/etc/flexs/arca/flexs_homo.crt","key_path":"/etc/flexs/arca/flexs_homo.key"},"production":{"cuit":"20113124572","cert_path":"/etc/flexs/arca/flexs_prod.crt","key_path":"/etc/flexs/arca/flexs_prod.key"}},"ubolt":{"homologation":{"cuit":"REEMPLAZAR_CUIT_UBOLT","cert_path":"/etc/flexs/arca/ubolt_homo.crt","key_path":"/etc/flexs/arca/ubolt_homo.key"},"production":{"cuit":"REEMPLAZAR_CUIT_UBOLT","cert_path":"/etc/flexs/arca/ubolt_prod.crt","key_path":"/etc/flexs/arca/ubolt_prod.key"}}}

# Fiscal emission guards and retries
FISCAL_RETRY_MINUTES=10
FISCAL_MAX_AUTO_RETRIES=5
FISCAL_SUBMITTING_TIMEOUT_MINUTES=20
FISCAL_ALLOW_ZERO_IVA_ARCA=False

# ARCA numbering sync before emission: never | first | always
FISCAL_ARCA_LAST_AUTH_SYNC_POLICY=first
FISCAL_ARCA_REQUIRE_LAST_AUTH_SYNC=False

# Automatic item tax snapshot on fiscal documents
FISCAL_AUTO_ITEM_TAX_ENABLED=True
FISCAL_ITEM_TAX_CALCULATION_MODE=gross
FISCAL_APPLY_TAX_TO_MANUAL_DOCS=False
# Example JSON:
# {"FA":"21","FB":"21","FC":"0","NCA":"21","NDA":"21"}
FISCAL_DOC_TYPE_DEFAULT_IVA_RATES_JSON={}
